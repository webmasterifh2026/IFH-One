{
  "name": "ifh-one",
  "version": "3.0.3",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "start:web": "npm --workspace apps/web run start",
    "start:api": "npm --workspace apps/api run start:prod",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "version:sync": "node scripts/sync-version.js",
    "prepare": "echo skip husky"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "turbo": "^1.13.3"
  }
}
