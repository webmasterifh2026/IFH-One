DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://ifh-one-web.vercel.app
AUTH_SECRET=change-me-in-production-min-32-chars
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=8h

# Email sending is a hard kill-switch, independent of SMTP config below —
# set to "true" to actually send mail. Defaults to disabled (v2.8.2).
# EMAIL_ENABLED=true

# SMTP — leave blank to disable email sending (logs only)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
# EMAIL_FROM=noreply@ifh-one.com

# Comma-separated list of email addresses to CC on every workflow notification
# NOTIFICATION_CC_EMAILS=user1@company.com,user2@company.com

# ─── Email / SMTP ────────────────────────────────────────────────────────────
# Without these, EmailService falls back to log-only mode (no real send).
# Get these from your mailbox provider's SMTP / outgoing-mail settings
# (e.g. cPanel "Email Accounts > Connect Devices", Office365 admin, or
# Google Workspace admin > SMTP relay). SMTP_PASSWORD should be an app
# password if the provider supports one, not the mailbox login password.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=webmaster@intensiv-filter-himenviro.com
SMTP_PASSWORD=change-me
EMAIL_FROM=webmaster@intensiv-filter-himenviro.com
