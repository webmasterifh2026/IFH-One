// ═══════════════════════════════════════════════════════════════════════════
// RFQ Float Workflow — v2.11.0
// Multi-indent RFQ float, TCE, and negotiation
// ═══════════════════════════════════════════════════════════════════════════

model RFQFloat {
  id                    String              @id @default(uuid())
  rfqNumber             String              @unique
  rfqDate               DateTime            @default(now())
  submissionDeadline    DateTime?
  expectedDeliveryDate  DateTime?
  filledById            String?
  deliveryLocation      String?
  remarks               String?
  status                String              @default("DRAFT")
  createdById           String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  items                 RFQFloatItem[]
  vendors               RFQFloatVendor[]
  tces                  TCE[]
  negotiations          Negotiation[]
  activityLogs          RFQFloatActivityLog[]
  emailLogs             RFQFloatEmailLog[]

  @@index([rfqNumber])
  @@index([status])
  @@index([createdById])
}

model RFQFloatItem {
  id                  String      @id @default(uuid())
  rfqFloatId          String
  indentId            String
  indentItemId        String
  itemCode            String?
  itemName            String
  description         String?
  itemRemarks         String?
  make                String?
  quantity            Decimal     @db.Decimal(15, 3)
  uom                 String?
  unitWeight          Decimal?    @db.Decimal(15, 3)
  totalWeight         Decimal?    @db.Decimal(15, 3)
  isAvailableInStore  Boolean     @default(false)
  isSelected          Boolean     @default(true)
  createdAt           DateTime    @default(now())

  rfqFloat            RFQFloat    @relation(fields: [rfqFloatId], references: [id], onDelete: Cascade)
  tceItems            TCEItem[]

  @@index([rfqFloatId])
  @@index([indentId])
  @@index([indentItemId])
}

model RFQFloatVendor {
  id          String      @id @default(uuid())
  rfqFloatId  String
  vendorId    String?
  vendorCode  String?
  vendorName  String
  email       String?
  phone       String?
  status      String      @default("PENDING")
  sentDate    DateTime?

  rfqFloat    RFQFloat    @relation(fields: [rfqFloatId], references: [id], onDelete: Cascade)
  vendor      Vendor?     @relation(fields: [vendorId], references: [id])

  @@index([rfqFloatId])
  @@index([vendorId])
}

model TCE {
  id              String      @id @default(uuid())
  rfqFloatId      String
  vendorFormId    String?
  vendorId        String?
  vendorName      String
  quotationId     String?
  quotationNumber String?
  submittedAt     DateTime?
  grandTotal      Decimal?    @db.Decimal(15, 2)
  deliveryBasis   String?
  warranty        String?
  remarks         String?
  status          String      @default("PENDING")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  rfqFloat        RFQFloat        @relation(fields: [rfqFloatId], references: [id], onDelete: Cascade)
  items           TCEItem[]
  attachments     TCEAttachment[]

  @@index([rfqFloatId])
  @@index([vendorId])
}

model TCEItem {
  id                  String      @id @default(uuid())
  tceId               String
  rfqFloatItemId      String?
  itemCode            String?
  itemName            String
  quantity            Decimal?    @db.Decimal(15, 3)
  uom                 String?
  quotedRate          Decimal?    @db.Decimal(15, 2)
  discountPercentage  Decimal?    @db.Decimal(5, 2)
  discountAmount      Decimal?    @db.Decimal(15, 2)
  gstPercentage       Decimal?    @db.Decimal(5, 2)
  gstAmount           Decimal?    @db.Decimal(15, 2)
  totalAmount         Decimal?    @db.Decimal(15, 2)
  deliveryBasis       String?
  supplierRemark      String?
  createdAt           DateTime    @default(now())

  tce                 TCE             @relation(fields: [tceId], references: [id], onDelete: Cascade)
  rfqFloatItem        RFQFloatItem?   @relation(fields: [rfqFloatItemId], references: [id])

  @@index([tceId])
  @@index([rfqFloatItemId])
}

model TCEAttachment {
  id          String      @id @default(uuid())
  tceId       String
  fileName    String
  fileType    String
  fileSize    Int?
  fileUrl     String
  uploadedAt  DateTime    @default(now())

  tce         TCE         @relation(fields: [tceId], references: [id], onDelete: Cascade)

  @@index([tceId])
}

model Negotiation {
  id              String      @id @default(uuid())
  rfqFloatId      String
  tceId           String?
  vendorId        String?
  vendorName      String
  status          String      @default("PENDING")  // PENDING | ACTIVE | COMPLETED | CANCELLED
  startedAt       DateTime    @default(now())
  completedAt     DateTime?
  remarks         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  rfqFloat        RFQFloat        @relation(fields: [rfqFloatId], references: [id], onDelete: Cascade)
  items           NegotiationItem[]

  @@index([rfqFloatId])
  @@index([vendorId])
}

model NegotiationItem {
  id                  String      @id @default(uuid())
  negotiationId       String
  tceItemId           String?
  itemCode            String?
  itemName            String
  quantity            Decimal?    @db.Decimal(15, 3)
  uom                 String?
  originalRate        Decimal?    @db.Decimal(15, 2)
  negotiatedRate      Decimal?    @db.Decimal(15, 2)
  finalRate           Decimal?    @db.Decimal(15, 2)
  discountPercentage  Decimal?    @db.Decimal(5, 2)
  deliveryTerms       String?
  paymentTerms        String?
  remarks             String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  negotiation         Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  @@index([negotiationId])
  @@index([tceItemId])
}

model RFQFloatActivityLog {
  id              String      @id @default(uuid())
  rfqFloatId      String
  action          String
  description     String?
  performedById   String?
  performedByName String?
  metadata        String?
  createdAt       DateTime    @default(now())

  rfqFloat        RFQFloat    @relation(fields: [rfqFloatId], references: [id], onDelete: Cascade)

  @@index([rfqFloatId])
  @@index([action])
}

model RFQFloatEmailLog {
  id              String      @id @default(uuid())
  rfqFloatId      String
  emailType       String
  recipientEmail  String
  subject         String
  body            String?
  sentAt          DateTime    @default(now())
  deliveryStatus  String      @default("SENT")
  bounceReason    String?

  rfqFloat        RFQFloat    @relation(fields: [rfqFloatId], references: [id], onDelete: Cascade)

  @@index([rfqFloatId])
  @@index([emailType])
  @@index([deliveryStatus])
}
