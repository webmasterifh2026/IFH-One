NEXT_PUBLIC_APP_NAME=IFH One
NEXT_PUBLIC_ENVIRONMENT=production

# INTENTIONALLY EMPTY on Vercel deployment.
# apiFetch will use relative /api/... URLs which are handled by vercel.json rewrites.
# This avoids CORS issues and keeps the Railway URL server-side only.
# If deploying to a platform OTHER than Vercel, set this to your API URL.
NEXT_PUBLIC_API_URL=
