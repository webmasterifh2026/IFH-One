{
  "version": 2,
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ifh-one-api-production.up.railway.app/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "X-Forwarded-Host", "value": "ifh-one-web.vercel.app" }
      ]
    }
  ]
}
