# IFH One - Environment Configuration (.env.example)

# ==========================================
# Frontend (Vercel / Next.js) Variables
# ==========================================
NEXT_PUBLIC_APP_NAME="IFH One"
NEXT_PUBLIC_API_URL="https://api.yourdomain.com"
NEXT_PUBLIC_ENVIRONMENT="production"

# ==========================================
# Backend (Railway / NestJS) Variables
# ==========================================
NODE_ENV="production"
PORT=3001
APP_URL="https://api.yourdomain.com"
FRONTEND_URL="https://app.yourdomain.com"
BACKEND_URL="https://api.yourdomain.com"

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-shadow-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Authentication / Security
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRY="7d"
SESSION_SECRET="your-session-secret-key"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@example.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL="noreply@example.com"

# File Upload Configuration
FILE_UPLOAD_PATH="./uploads"
MAX_UPLOAD_SIZE="5242880" # 5MB in bytes
